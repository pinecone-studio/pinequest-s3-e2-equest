# Copy this file to `.dev.vars` for local OpenNext/Wrangler runs.
# Keep real secrets only in `.dev.vars`, `.env.local`, or Cloudflare secrets.

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_DATABASE_ID=your-d1-database-id
CLOUDFLARE_D1_TOKEN=your-d1-api-token

GRAPHQL_CORS_ORIGINS=http://localhost:3000

ABLY_API_KEY=your-ably-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# R2 S3-compatible credentials for `/api/r2`
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=exam
R2_ENDPOINT=https://your-public-bucket-subdomain.r2.dev
R2_S3_API=https://your-account-id.r2.cloudflarestorage.com

# Frontend-facing helpers
NEXT_PUBLIC_R2_BUCKET_NAME=exam
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-public-bucket-subdomain.r2.dev
NEXT_PUBLIC_R2_PRESIGN_URL=https://take-exam-service.example.workers.dev/api/proctoring-screenshots/presign
